{
  "name": "theorvane-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "workspaces": ["apps/*", "packages/*"],
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "npm run test:contracts && turbo run test",
    "test:contracts": "node --test test/*.test.mjs",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "globals": "^16.5.0",
    "turbo": "^2.10.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.50.1"
  }
}
